module Growsurf
  module Models
    module Campaign
      type reward_fulfill_params =
        { id: String, reward_id: String }
        & Growsurf::Internal::Type::request_parameters

      class RewardFulfillParams < Growsurf::Internal::Type::BaseModel
        extend Growsurf::Internal::Type::RequestParameters::Converter
        include Growsurf::Internal::Type::RequestParameters

        attr_accessor id: String

        attr_accessor reward_id: String

        def initialize: (
          id: String,
          reward_id: String,
          ?request_options: Growsurf::request_opts
        ) -> void

        def to_hash: -> {
          id: String,
          reward_id: String,
          request_options: Growsurf::RequestOptions
        }
      end
    end
  end
end
