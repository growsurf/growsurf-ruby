module Growsurf
  module Models
    module Campaign
      type participant_list_rewards_response =
        {
          limit: Integer,
          next_id: String?,
          rewards: ::Array[Growsurf::Campaign::ParticipantReward]
        }

      class ParticipantListRewardsResponse < Growsurf::Internal::Type::BaseModel
        attr_accessor limit: Integer

        attr_accessor next_id: String?

        attr_accessor rewards: ::Array[Growsurf::Campaign::ParticipantReward]

        def initialize: (
          limit: Integer,
          next_id: String?,
          rewards: ::Array[Growsurf::Campaign::ParticipantReward]
        ) -> void

        def to_hash: -> {
          limit: Integer,
          next_id: String?,
          rewards: ::Array[Growsurf::Campaign::ParticipantReward]
        }
      end
    end
  end
end
