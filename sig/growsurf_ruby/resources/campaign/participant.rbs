module GrowsurfRuby
  module Resources
    class Campaign
      class Participant
        def retrieve: (
          String participant_id_or_email,
          id: String,
          ?request_options: GrowsurfRuby::request_opts
        ) -> GrowsurfRuby::Campaign::CampaignParticipant

        def update: (
          String participant_id_or_email,
          id: String,
          ?email: String,
          ?first_name: String,
          ?last_name: String,
          ?metadata: ::Hash[Symbol, top],
          ?referral_status: GrowsurfRuby::Models::Campaign::ParticipantUpdateParams::referral_status,
          ?referred_by: String,
          ?unsubscribed: bool,
          ?vanity_keys: ::Array[String],
          ?request_options: GrowsurfRuby::request_opts
        ) -> GrowsurfRuby::Campaign::CampaignParticipant

        def delete: (
          String participant_id_or_email,
          id: String,
          ?request_options: GrowsurfRuby::request_opts
        ) -> GrowsurfRuby::Models::Campaign::ParticipantDeleteResponse

        def add: (
          String id,
          email: String,
          ?fingerprint: String,
          ?first_name: String,
          ?ip_address: String,
          ?last_name: String,
          ?metadata: ::Hash[Symbol, top],
          ?mobile_instance_id: String,
          ?referral_status: GrowsurfRuby::Models::Campaign::Create::referral_status,
          ?referred_by: String,
          ?request_options: GrowsurfRuby::request_opts
        ) -> GrowsurfRuby::Campaign::CampaignParticipant

        def list_commissions: (
          String participant_id_or_email,
          id: String,
          ?limit: Integer,
          ?next_id: String,
          ?status: GrowsurfRuby::Models::Campaign::ParticipantListCommissionsParams::status,
          ?request_options: GrowsurfRuby::request_opts
        ) -> GrowsurfRuby::ParticipantCommissionList

        def list_payouts: (
          String participant_id_or_email,
          id: String,
          ?limit: Integer,
          ?next_id: String,
          ?status: GrowsurfRuby::Models::Campaign::ParticipantListPayoutsParams::status,
          ?request_options: GrowsurfRuby::request_opts
        ) -> GrowsurfRuby::ParticipantPayoutList

        def list_referrals: (
          String participant_id_or_email,
          id: String,
          ?desc: bool,
          ?email: String,
          ?first_name: String,
          ?last_name: String,
          ?limit: Integer,
          ?next_id: String,
          ?offset: Integer,
          ?referral_status: GrowsurfRuby::Models::Campaign::referral_status,
          ?sort_by: GrowsurfRuby::Models::Campaign::ParticipantListReferralsParams::sort_by,
          ?request_options: GrowsurfRuby::request_opts
        ) -> GrowsurfRuby::ReferralList

        def list_rewards: (
          String participant_id_or_email,
          id: String,
          ?limit: Integer,
          ?next_id: String,
          ?request_options: GrowsurfRuby::request_opts
        ) -> GrowsurfRuby::Models::Campaign::ParticipantListRewardsResponse

        def record_transaction: (
          String participant_id_or_email,
          id: String,
          currency: String,
          gross_amount: Integer,
          ?amount_cash_net: Integer,
          ?amount_paid: Integer,
          ?charge_id: String,
          ?customer_id: String,
          ?description: String,
          ?external_id: String,
          ?invoice_id: String,
          ?invoice_subtotal_excluding_tax: Integer,
          ?invoice_total: Integer,
          ?invoice_total_excluding_tax: Integer,
          ?net_amount: Integer,
          ?order_id: String,
          ?paid_at: Integer,
          ?payment_id: String,
          ?payment_intent_id: String,
          ?subscription_id: String,
          ?tax_amount: Integer,
          ?total_tax_amount: Integer,
          ?total_tax_amounts: ::Array[::Hash[Symbol, top]],
          ?total_taxes: ::Array[::Hash[Symbol, top]],
          ?transaction_id: String,
          ?request_options: GrowsurfRuby::request_opts
        ) -> GrowsurfRuby::Models::Campaign::participant_record_transaction_response

        def refund_transaction: (
          String participant_id_or_email,
          id: String,
          ?amendment_type: GrowsurfRuby::Models::Campaign::ParticipantRefundTransactionParams::amendment_type,
          ?amount: Integer,
          ?amount_refunded: Integer,
          ?charge_id: String,
          ?currency: String,
          ?description: String,
          ?external_id: String,
          ?invoice_id: String,
          ?order_id: String,
          ?payment_id: String,
          ?payment_intent_id: String,
          ?refund_amount: Integer,
          ?refund_id: String,
          ?refund_status: String,
          ?transaction_id: String,
          ?request_options: GrowsurfRuby::request_opts
        ) -> GrowsurfRuby::Models::Campaign::ParticipantRefundTransactionResponse

        def send_invites: (
          String participant_id_or_email,
          id: String,
          email_addresses: ::Array[String],
          message_text: String,
          subject_text: String,
          ?request_options: GrowsurfRuby::request_opts
        ) -> GrowsurfRuby::Models::Campaign::ParticipantSendInvitesResponse

        def trigger_referral: (
          String participant_id_or_email,
          id: String,
          ?delay_in_days: Integer,
          ?request_options: GrowsurfRuby::request_opts
        ) -> GrowsurfRuby::Models::Campaign::ParticipantTriggerReferralResponse

        def cancel_delayed_referral: (
          String participant_id_or_email,
          id: String,
          ?request_options: GrowsurfRuby::request_opts
        ) -> GrowsurfRuby::Models::Campaign::ParticipantCancelDelayedReferralResponse

        def initialize: (client: GrowsurfRuby::Client) -> void
      end
    end
  end
end
