          participant_id_or_email: String,
          ?email: String,
          ?first_name: String,
          ?last_name: String,
          ?metadata: ::Hash[Symbol, top],
          ?notes: String,
          ?paypal_email: String,
          ?referral_status: GrowsurfRuby::Models::Campaign::ParticipantUpdateParams::referral_status,
          ?referred_by: String,
